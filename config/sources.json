{
  "rss": {
    "maxAgeDays": 2,
    "maxPerFeed": 10,
    "feeds": [
      {
        "url": "https://www.gov.uk/search/news-and-communications.atom",
        "topics": ["UK", "government"]
      },
      {
        "url": "https://news.un.org/feed/subscribe/en/news/all/rss.xml",
        "topics": ["UN", "world"]
      }
    ]
  },
  "scrape": {
    "maxAgeDays": 7,
    "maxPerSource": 8,
    "targets": [
      {
        "name": "StateCouncil",
        "domain": "english.www.gov.cn",
        "indexUrl": "https://english.www.gov.cn/news",
        "topics": ["China", "government"]
      },
      {
        "name": "WhiteHouse",
        "domain": "whitehouse.gov",
        "indexUrl": "https://www.whitehouse.gov/releases/",
        "topics": ["US", "government"]
      }
    ]
  }
}
