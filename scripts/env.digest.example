# Copy to scripts/.env.digest.local and fill in (gitignored).
#
# Option A — Vercel Dashboard (recommended): Project → Settings → Environment Variables
#   Set all variables below for Production, then Redeploy.
#
# Option B — CLI helper:
#   bash scripts/configure-vercel-digest-env.sh

# --- 163 SMTP (client auth code, not web login password) ---
DIGEST_SMTP_USER=your-email@163.com
DIGEST_SMTP_PASS=YOUR_16_DIGIT_AUTH_CODE
# Optional: DIGEST_SMTP_HOST (default smtp.163.com), DIGEST_SMTP_PORT (default 465), DIGEST_SMTP_SECURE (default true)
# Optional: DIGEST_SMTP_MULTIPART_ALTERNATIVE=true for text+html multipart
DIGEST_TO_EMAIL=
# Sender must match SMTP login on 163; leave empty to default to DIGEST_SMTP_USER at runtime
# DIGEST_FROM_EMAIL=

# Optional: auto-generated by configure script if empty
# CRON_SECRET=
